generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categoria {
  id      String    @id
  nome    String    @unique(map: "Categoria_nome_key")
  slug    String    @unique(map: "Categoria_slug_key")
  produto produto[]
}

model endereco {
  id          String  @id
  usuarioId   String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  cep         String
  principal   Boolean @default(false)
  usuario     usuario @relation(fields: [usuarioId], references: [id], map: "Endereco_usuarioId_fkey")

  @@index([usuarioId], map: "Endereco_usuarioId_idx")
}

model imagemproduto {
  id        String  @id
  url       String
  produtoId String
  produto   produto @relation(fields: [produtoId], references: [id], onDelete: Cascade, map: "ImagemProduto_produtoId_fkey")

  @@index([produtoId], map: "ImagemProduto_produtoId_idx")
}

model itempedido {
  id                    String  @id
  pedidoId              String
  produtoId             String
  quantidade            Int
  precoUnitario         Decimal @db.Decimal(10, 2)
  nomePersonalizado     String?
  corPersonalizada      String?
  fontePersonalizada    String?
  sementePersonalizada  String?
  lacoPersonalizado     String?
  saquinhoPersonalizado String?
  tagPersonalizada      String?
  pedido                pedido  @relation(fields: [pedidoId], references: [id], map: "ItemPedido_pedidoId_fkey")
  produto               produto @relation(fields: [produtoId], references: [id], map: "ItemPedido_produtoId_fkey")

  @@index([pedidoId], map: "ItemPedido_pedidoId_idx")
  @@index([produtoId], map: "ItemPedido_produtoId_idx")
}

model opcaoproduto {
  id             String  @id
  produtoId      String
  tipo           String
  valor          String
  acrescimoPreco Decimal @default(0.00) @db.Decimal(10, 2)
  produto        produto @relation(fields: [produtoId], references: [id], map: "OpcaoProduto_produtoId_fkey")

  @@index([produtoId], map: "OpcaoProduto_produtoId_idx")
}

model pedido {
  id              String        @id
  usuarioId       String
  status          pedido_status @default(PENDENTE)
  total           Decimal       @db.Decimal(10, 2)
  custoFrete      Decimal       @db.Decimal(10, 2)
  metodoFrete     String
  metodoPagamento String
  transacaoId     String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime
  itempedido      itempedido[]
  usuario         usuario       @relation(fields: [usuarioId], references: [id], map: "Pedido_usuarioId_fkey")

  @@index([criadoEm], map: "Pedido_criadoEm_idx")
  @@index([status], map: "Pedido_status_idx")
  @@index([usuarioId], map: "Pedido_usuarioId_idx")
}

model produto {
  id            String          @id
  nome          String
  descricao     String          @db.Text
  precoBase     Decimal         @db.Decimal(10, 2)
  categoriaId   String
  ativo         Boolean         @default(true)
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime
  imagemproduto imagemproduto[]
  itempedido    itempedido[]
  opcaoproduto  opcaoproduto[]
  categoria     categoria       @relation(fields: [categoriaId], references: [id], map: "Produto_categoriaId_fkey")

  @@index([ativo], map: "Produto_ativo_idx")
  @@index([categoriaId], map: "Produto_categoriaId_idx")
}

model usuario {
  id           String       @id
  nome         String?
  email        String       @unique(map: "Usuario_email_key")
  senha        String
  tipo         usuario_tipo @default(CLIENTE)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime
  endereco     endereco[]
  pedido       pedido[]

  @@index([tipo], map: "Usuario_tipo_idx")
}

enum pedido_status {
  PENDENTE
  PAGO
  EM_PRODUCAO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum usuario_tipo {
  CLIENTE
  ADMIN
}
